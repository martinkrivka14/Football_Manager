generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String?
  code      String? 
  country   String?
  founded   Int?
  national  Boolean  @default(false)
  logo      String?
  leagueId  Int?
  league    League?  @relation(fields: [leagueId], references: [id])
  venues    Venue?
  players   Player[] 

  saveTeams SaveTeam[]
}

model Venue {
  id        Int      @id @default(autoincrement())
  name      String?
  address   String?
  city      String?
  capacity  Int?
  surface   String?
  image     String?
  team      Team?    @relation(fields: [teamId], references: [id])
  teamId    Int?     @unique
}

model League {
  id        Int      @id @default(autoincrement())
  name      String?
  logo      String?
  teams     Team[]

  saveLeagues SaveLeague[]
}

model Player {
  id            Int      @id @default(autoincrement())
  name          String?
  firstname     String? 
  lastname      String?
  age           Int?
  nationality   String?
  height        Int?
  weight        Int?
  jerseyNumber  Int?
  position      String?
  photo         String?
  overall       Int?     
  teamId        Int?     
  team          Team?    @relation(fields: [teamId], references: [id])

  savePlayers SavePlayer[]
}



model GameSave {
  id          String   @id @default(cuid()) 
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  saveName    String   
  inGameDate  DateTime @default(now()) 
  
  
  userTeamId  String?
  userTeam    SaveTeam? @relation("ManagedTeam", fields: [userTeamId], references: [id], onDelete: SetNull)

  
  leagues     SaveLeague[]
  teams       SaveTeam[]
  players     SavePlayer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saveLineups SaveLineup[]
}

model SaveTeam {
  id              String    @id @default(cuid())
  
  gameSaveId      String
  gameSave        GameSave  @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  
  
  originalTeamId  Int
  originalTeam    Team      @relation(fields: [originalTeamId], references: [id]) 
  
  
  budget          Int       @default(0) 

  saveLeagueId    String?
  saveLeague      SaveLeague? @relation(fields: [saveLeagueId], references: [id], onDelete: SetNull)
  
  players         SavePlayer[] @relation("SaveTeamPlayers")
  managedBy       GameSave[]   @relation("ManagedTeam")


  saveLineups SaveLineup[]
}

model SavePlayer {
  id                String    @id @default(cuid())
  gameSaveId        String
  gameSave          GameSave  @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  originalPlayerId  Int
  originalPlayer    Player    @relation(fields: [originalPlayerId], references: [id]) 
  
  overall           Int?      
  age               Int?      
  saveTeamId        String?
  saveTeam          SaveTeam? @relation("SaveTeamPlayers", fields: [saveTeamId], references: [id], onDelete: SetNull)

  condition         Int       @default(100)       
  morale            String    @default("NORMAL")  

  lineupEntries     SaveLineupEntry[]
}


model SaveLineup {
  id          String   @id @default(cuid())
  name        String   @default("Základní Sestava")
  
  gameSaveId  String
  gameSave    GameSave @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  
  saveTeamId  String
  saveTeam    SaveTeam @relation(fields: [saveTeamId], references: [id], onDelete: Cascade)


  entries     SaveLineupEntry[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model SaveLineupEntry {
  id              String      @id @default(cuid())
  
  saveLineupId    String
  saveLineup      SaveLineup  @relation(fields: [saveLineupId], references: [id], onDelete: Cascade)
  
  savePlayerId    String
  savePlayer      SavePlayer  @relation(fields: [savePlayerId], references: [id], onDelete: Cascade)

  
  role            String      
  
  
  pitchPosition   String?     

  @@unique([saveLineupId, savePlayerId])
}

model SaveLeague {
  id               String     @id @default(cuid())
  
  gameSaveId       String
  gameSave         GameSave   @relation(fields: [gameSaveId], references: [id], onDelete: Cascade)
  
  
  originalLeagueId Int
  originalLeague   League     @relation(fields: [originalLeagueId], references: [id])
  

  saveTeams SaveTeam[]
}



 
model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameSaves GameSave[]
}
 
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}
 
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([userId, credentialID])

}

